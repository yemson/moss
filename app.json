{
  "expo": {
    "name": "Moss",
    "slug": "moss",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/moss-logo.png",
    "scheme": "moss",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/moss.icon",
      "bundleIdentifier": "com.yemson.moss",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/moss-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/images/moss-logo.png"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "891020d1-ed38-46db-9ab5-c6f87ad64e85"
      }
    },
    "owner": "yemson",
    "android": {
      "package": "com.yemson.moss"
    }
  }
}
